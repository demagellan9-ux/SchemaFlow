# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | testing | production
DEBUG=false
LOG_LEVEL=INFO

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=<supabase-jwt-secret>
JWT_ALGORITHM=HS256

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── ETL Runner ────────────────────────────────────────────────────────────────
ETL_RUNNER=subprocess        # subprocess | http | celery
ETL_HTTP_URL=                # Required only when ETL_RUNNER=http

# ── Internal security ─────────────────────────────────────────────────────────
INTERNAL_WEBHOOK_SECRET=<generate-a-strong-random-secret>
